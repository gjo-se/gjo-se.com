# gjo-se.com – Root environment variables
# Copy this file to .env and fill in real values. Never commit .env to Git.

# Application
APP_NAME=gjo-se.com
DEBUG=false
ENVIRONMENT=dev
ALLOWED_ORIGINS=["http://localhost:3000"]

# PostgreSQL (Docker-intern: Hostname = "db")
DATABASE_URL=postgresql+asyncpg://gjose_user:gjose_dev@db:5432/gjose
DB_PASSWORD=gjose_dev
