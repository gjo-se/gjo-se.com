# gjo-se.com – Root environment variables
# Copy this file to .env and fill in real values. Never commit .env to Git.

# Application
APP_NAME=gjo-se.com
DEBUG=false
ENVIRONMENT=dev
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# PostgreSQL (Docker-intern: Hostname = "db")
# Ersetze <your-password> mit einem echten Passwort in der .env
DATABASE_URL=postgresql+asyncpg://gjose_user:<your-password>@db:5432/gjose
DB_PASSWORD=<your-password>

# Auth / JWT
SECRET_KEY=<generate-a-strong-secret>
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256
COOKIE_SECURE=False
