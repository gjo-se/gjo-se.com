# gjo-se.com – Backend environment variables
# Copy this file to .env and fill in real values. Never commit .env to Git.

APP_NAME=gjo-se.com
DEBUG=false
ENVIRONMENT=dev
# PostgreSQL – lokale Entwicklung, Integration-Tests und Produktion (Default)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/gjose
# SQLite – ausschliesslich für Unit-Tests (in-memory), nie für lokale Entwicklung
# DATABASE_URL=sqlite+aiosqlite:///:memory:
ALLOWED_ORIGINS=["http://localhost:3000"]
